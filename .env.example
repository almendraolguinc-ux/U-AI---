# Credenciales para el Portal de Admisión UAI
UAI_USER="tu_usuario@uai.cl"
UAI_PASSWORD="tu_password"

# Configuración del Servidor de Correo Saliente (SMTP)
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER="tu_correo@uai.cl"
SMTP_PASSWORD="tu_password_de_correo"
EMAIL_FROM="tu_correo@uai.cl"

# Opciones de Ejecución del RPA
HEADLESS=false
DOWNLOAD_DIR="descargas_postulantes"
REPORTE_FINAL="resultado_proceso_rpa.xlsx"

# ID de la carpeta compartida de Google Drive
DRIVE_FOLDER_ID="ID_DE_TU_CARPETA_DE_GOOGLE_DRIVE"

# Nombres de las columnas clave en el Excel descargado (ajustar si cambian en el portal)
COL_EMAIL="MAIL"
COL_PREFERENCIA="PrimeraPreferencia"
COL_PUNTAJE_PAES="MaximoPuntajePAESPrimeraPreferencia"
COL_NEM="PromedioNotasEnseñanzaMedia"
COL_DOCS_ENVIADOS="DocumentosRequeridosAdjuntos"
